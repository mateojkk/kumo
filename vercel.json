{
  "buildCommand": "npm run build --workspace=apps/web",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "apps/api/src/functions/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/remember",   "destination": "/apps/api/src/functions/remember" },
    { "source": "/recall",     "destination": "/apps/api/src/functions/recall" },
    { "source": "/analyze",    "destination": "/apps/api/src/functions/analyze" },
    { "source": "/discover",   "destination": "/apps/api/src/functions/discover" },
    { "source": "/registry",   "destination": "/apps/api/src/functions/registry" },
    { "source": "/agent/:id",  "destination": "/apps/api/src/functions/profile" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-agent-id, x-api-key" }
      ]
    }
  ]
}
