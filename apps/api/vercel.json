{
  "version": 2,
  "functions": {
    "src/functions/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/remember",     "destination": "/src/functions/remember" },
    { "source": "/recall",       "destination": "/src/functions/recall" },
    { "source": "/analyze",      "destination": "/src/functions/analyze" },
    { "source": "/discover",     "destination": "/src/functions/discover" },
    { "source": "/registry",     "destination": "/src/functions/registry" },
    { "source": "/agent/:id",    "destination": "/src/functions/profile" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-agent-id, x-api-key" }
      ]
    }
  ]
}
